{
  "info": {
    "_postman_id": "8b5f3a09-7a32-47ef-8d62-a25e1bb34b9d",
    "name": "WatchMart API Collection",
    "description": "คอลเลกชันรวม API ทั้งหมดของระบบ WatchMart สำหรับทดสอบระบบด้วย Postman ครอบคลุมฟังก์ชันของผู้ซื้อ ผู้จัดการ และผู้ดูแลระบบ",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication (การยืนยันตัวตน)",
      "item": [
        {
          "name": "สมัครสมาชิกลูกค้า (Register Customer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"buyer_test\",\n  \"password\": \"password123\",\n  \"email\": \"buyer@watchmart.com\",\n  \"firstname\": \"สมชาย\",\n  \"lastname\": \"ใจดี\",\n  \"phone\": \"0899999999\",\n  \"address\": \"123 ถนนวิภาวดีรังสิต กรุงเทพฯ\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "ใช้สำหรับการลงทะเบียนลูกค้าใหม่เข้าสู่ระบบ"
          },
          "response": []
        },
        {
          "name": "ล็อกอินลูกค้า (Login - Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"เข้าสู่ระบบสำเร็จ - Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"บทบาทผู้ใช้ถูกต้อง\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.user.role).to.eql(\"user\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"user\",\n  \"username\": \"buyer_test\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "เข้าสู่ระบบในบทบาทลูกค้าทั่วไป"
          },
          "response": []
        },
        {
          "name": "ล็อกอินผู้จัดการ (Login - Manager)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"manager\",\n  \"username\": \"manager\",\n  \"password\": \"manager123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "เข้าสู่ระบบในบทบาทผู้จัดการร้านเพื่อจัดการสินค้าและตรวจสลิป"
          },
          "response": []
        },
        {
          "name": "ล็อกอินแอดมิน (Login - Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\",\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "เข้าสู่ระบบในบทบาทแอดมินเพื่อกดยืนยันออเดอร์ขั้นสุดท้าย"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Products Catalog (แคตตาล็อกสินค้า)",
      "item": [
        {
          "name": "ดึงข้อมูลนาฬิกาทั้งหมด (Get Products)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "เรียกดูข้อมูลรายการนาฬิกาหรูทั้งหมดในสต็อก พร้อมคะแนนดาวรีวิวเฉลี่ย"
          },
          "response": []
        },
        {
          "name": "ค้นหาและกรองนาฬิกา (Search & Filter Products)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products?category=classic&search=Seiko",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "classic"
                },
                {
                  "key": "search",
                  "value": "Seiko"
                }
              ]
            },
            "description": "ค้นหานาฬิกาตามกลุ่มประเภทสินค้าและคีย์เวิร์ดชื่อแบรนด์"
          },
          "response": []
        },
        {
          "name": "เพิ่มนาฬิกาใหม่ (Add Product - Manager Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Seiko Presage Cocktail Time\",\n  \"brand\": \"Seiko\",\n  \"category\": \"elegant\",\n  \"price\": 18500,\n  \"stock\": 10,\n  \"color\": \"#e2e8f0\",\n  \"strokeColor\": \"#c5a880\",\n  \"image\": \"\",\n  \"imageBack\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "สิทธิ์ผู้จัดการใช้สำหรับนำเข้านาฬิการุ่นใหม่สู่คลังสินค้า"
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Orders & Payment (การจองและชำระเงิน)",
      "item": [
        {
          "name": "ดึงข้อมูลออเดอร์ทั้งหมด (Get Orders)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "เรียกดูประวัติออเดอร์ทั้งหมดในระบบ"
          },
          "response": []
        },
        {
          "name": "สร้างออเดอร์จองนาฬิกา (Create Order - Pay Later)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"buyer_test\",\n  \"email\": \"buyer@watchmart.com\",\n  \"address\": \"123 SPU Road, Bangkok\",\n  \"payment\": \"โอนเงินธนาคาร (แนบสลิป)\",\n  \"items\": [\n    {\n      \"id\": \"1\",\n      \"name\": \"Luminox ASIA LITE\",\n      \"price\": 9500,\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "ทำการเช็คเอาท์เพื่อตัดสต็อกนาฬิกาและรับสถานะ pending_payment"
          },
          "response": []
        },
        {
          "name": "แนบสลิปโอนเงิน (Submit Payment Slip)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slip\": \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/ใส่รหัสออเดอร์ที่นี่/submit-slip",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders",
                "ใส่รหัสออเดอร์ที่นี่",
                "submit-slip"
              ]
            },
            "description": "ลูกค้าอัปโหลดภาพสลิปเงินโอน เพื่อเปลี่ยนสถานะออเดอร์เป็น pending_review (รอตรวจสอบสลิป)"
          },
          "response": []
        },
        {
          "name": "ผู้จัดการตรวจสอบอนุมัติสลิป (Manager Approve Slip)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/manager/approve-slip/ใส่รหัสออเดอร์ที่นี่",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "manager",
                "approve-slip",
                "ใส่รหัสออเดอร์ที่นี่"
              ]
            },
            "description": "สิทธิ์ผู้จัดการใช้สำหรับกดตรวจสอบสลิปว่ายอดเงินถูกต้องจริง เพื่อเปลี่ยนสถานะออเดอร์เป็น manager_approved"
          },
          "response": []
        },
        {
          "name": "แอดมินยืนยันยอดเงินสุดท้าย (Admin Final Confirm)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/confirm-order/ใส่รหัสออเดอร์ที่นี่",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "confirm-order",
                "ใส่รหัสออเดอร์ที่นี่"
              ]
            },
            "description": "สิทธิ์แอดมินสูงสุดเป็นผู้ตรวจสอบออเดอร์ที่ผู้จัดการกรองแล้ว และกดยืนยันการรับเงินขั้นสุดท้ายเพื่อส่งสินค้า (สถานะเปลี่ยนเป็น confirmed)"
          },
          "response": []
        },
        {
          "name": "ผู้จัดการจัดส่งสินค้า (Manager Ship Order)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/manager/ship-order/ใส่รหัสออเดอร์ที่นี่",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "manager",
                "ship-order",
                "ใส่รหัสออเดอร์ที่นี่"
              ]
            },
            "description": "ผู้จัดการเปลี่ยนสถานะออเดอร์เป็น shipped หลังจัดส่งนาฬิกาเรียบร้อย"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ]
}
